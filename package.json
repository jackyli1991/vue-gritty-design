{
  "name": "@vue-gritty-design/monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter vue-gritty-design dev",
    "build": "pnpm --filter vue-gritty-design build",
    "dev:mock": "pnpm --filter nitro-mock dev",
    "build:mock": "pnpm --filter nitro-mock build",
    "build:table": "pnpm --filter vue-design-table build",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "oxfmt apps/",
    "prepare": "husky"
  },
  "dependencies": {
    "@vitest/eslint-plugin": "^1.6.15",
    "@vue/eslint-config-typescript": "^14.7.0",
    "eslint-plugin-playwright": "^2.10.1",
    "eslint-plugin-vue": "~10.8.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.57.0",
    "husky": "^9.1.7",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.42.0",
    "oxlint": "~1.57.0",
    "typescript": "~6.0.2"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
